---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Register" description="Register for CloudConf 2026">
  <style>
    .register-hero {
      background: linear-gradient(135deg, #0a0e27 0%, #1a237e 100%);
      color: #ffffff;
      padding: 3rem 0;
      margin-bottom: 3rem;
    }

    .register-hero h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }

    .register-hero p {
      font-size: 1.1rem;
      color: #e0e0e0;
    }

    .register-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .register-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      margin-bottom: 3rem;
    }

    .register-info h2 {
      font-size: 2rem;
      color: #0a0e27;
      margin-bottom: 1.5rem;
    }

    .register-info p {
      color: #555;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .ticket-types {
      margin-top: 2rem;
    }

    .ticket-type {
      background: #f9f9f9;
      padding: 1.5rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      border-left: 4px solid #64b5f6;
    }

    .ticket-type h3 {
      font-size: 1.2rem;
      color: #0a0e27;
      margin-bottom: 0.5rem;
    }

    .ticket-price {
      font-size: 1.5rem;
      font-weight: 700;
      color: #64b5f6;
      margin-bottom: 0.5rem;
    }

    .ticket-description {
      color: #666;
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
    }

    .ticket-features {
      list-style: none;
      margin-top: 0.5rem;
    }

    .ticket-features li {
      color: #555;
      font-size: 0.9rem;
      padding: 0.25rem 0;
    }

    .ticket-features li::before {
      content: '✓ ';
      color: #64b5f6;
      font-weight: bold;
      margin-right: 0.5rem;
    }

    .form-section {
      background: #f5f5f5;
      padding: 2rem;
      border-radius: 8px;
    }

    .form-section h2 {
      font-size: 1.5rem;
      color: #0a0e27;
      margin-bottom: 1.5rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: #0a0e27;
      font-weight: 500;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-family: inherit;
      font-size: 1rem;
      transition: border-color 0.2s ease;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #64b5f6;
      box-shadow: 0 0 0 3px rgba(100, 181, 246, 0.1);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .submit-btn {
      background-color: #64b5f6;
      color: #0a0e27;
      padding: 1rem 2rem;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: 600;
      width: 100%;
      transition: all 0.3s ease;
    }

    .submit-btn:hover {
      background-color: #90caf9;
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(100, 181, 246, 0.3);
    }

    .note {
      background: #e3f2fd;
      border-left: 4px solid #0066cc;
      padding: 1rem;
      border-radius: 4px;
      margin-bottom: 2rem;
      color: #0a0e27;
    }

    .note strong {
      color: #0066cc;
    }

    @media (max-width: 768px) {
      .register-hero h1 {
        font-size: 2rem;
      }

      .register-content {
        grid-template-columns: 1fr;
      }

      .form-row {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <section class="register-hero">
    <div class="register-container">
      <h1>Register for CloudConf 2026</h1>
      <p>Secure your spot at the premier cloud infrastructure conference</p>
    </div>
  </section>

  <div class="register-container">
    <div class="register-content">
      <div class="register-info">
        <h2>Ticket Options</h2>
        <p>Choose the ticket type that best fits your needs. All tickets include access to all talks, workshops, meals, and networking events.</p>

        <div class="ticket-types">
          <div class="ticket-type">
            <h3>Early Bird</h3>
            <div class="ticket-price">$199</div>
            <div class="ticket-description">Limited availability - 50% off regular price</div>
            <ul class="ticket-features">
              <li>All conference sessions</li>
              <li>Meals and refreshments</li>
              <li>Networking events</li>
              <li>Conference materials</li>
            </ul>
          </div>

          <div class="ticket-type">
            <h3>Regular</h3>
            <div class="ticket-price">$399</div>
            <div class="ticket-description">Standard admission</div>
            <ul class="ticket-features">
              <li>All conference sessions</li>
              <li>Meals and refreshments</li>
              <li>Networking events</li>
              <li>Conference materials</li>
            </ul>
          </div>

          <div class="ticket-type">
            <h3>Group (5+)</h3>
            <div class="ticket-price">$349</div>
            <div class="ticket-description">Per person - minimum 5 tickets</div>
            <ul class="ticket-features">
              <li>All conference sessions</li>
              <li>Meals and refreshments</li>
              <li>Networking events</li>
              <li>Conference materials</li>
              <li>Group coordination support</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="form-section">
        <h2>Registration Form</h2>
        <div class="note">
          <strong>Note:</strong> This is a demonstration form. For actual registration, please visit our ticketing partner's website.
        </div>
        <form>
          <div class="form-group">
            <label for="ticket-type">Ticket Type *</label>
            <select id="ticket-type" name="ticket-type" required>
              <option value="">Select a ticket type</option>
              <option value="early-bird">Early Bird - $199</option>
              <option value="regular">Regular - $399</option>
              <option value="group">Group (5+) - $349</option>
            </select>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="first-name">First Name *</label>
              <input type="text" id="first-name" name="first-name" required />
            </div>
            <div class="form-group">
              <label for="last-name">Last Name *</label>
              <input type="text" id="last-name" name="last-name" required />
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email" required />
          </div>

          <div class="form-group">
            <label for="company">Company</label>
            <input type="text" id="company" name="company" />
          </div>

          <div class="form-group">
            <label for="job-title">Job Title</label>
            <input type="text" id="job-title" name="job-title" />
          </div>

          <div class="form-group">
            <label for="dietary">Dietary Restrictions</label>
            <input type="text" id="dietary" name="dietary" placeholder="e.g., vegetarian, vegan, gluten-free" />
          </div>

          <div class="form-group">
            <label for="interests">Topics of Interest</label>
            <textarea id="interests" name="interests" rows="3" placeholder="Tell us what topics you're most interested in..."></textarea>
          </div>

          <button type="submit" class="submit-btn">Complete Registration</button>
        </form>
      </div>
    </div>
  </div>
</Layout>
