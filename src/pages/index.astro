---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <style>
    .hero {
      background: linear-gradient(135deg, #0a0e27 0%, #1a237e 100%);
      color: #ffffff;
      padding: 4rem 0;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(100, 181, 246, 0.1) 0%, transparent 70%);
      border-radius: 50%;
    }

    .hero .container {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .hero-content h1 {
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
      line-height: 1.2;
      letter-spacing: -1px;
    }

    .hero-content p {
      font-size: 1.3rem;
      margin-bottom: 2rem;
      color: #e0e0e0;
      line-height: 1.6;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      padding: 0.875rem 2rem;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: 600;
      transition: all 0.3s ease;
      display: inline-block;
    }

    .btn-primary {
      background-color: #64b5f6;
      color: #0a0e27;
    }

    .btn-primary:hover {
      background-color: #90caf9;
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(100, 181, 246, 0.3);
    }

    .btn-secondary {
      background-color: transparent;
      color: #ffffff;
      border: 2px solid #64b5f6;
    }

    .btn-secondary:hover {
      background-color: #64b5f6;
      color: #0a0e27;
      transform: translateY(-2px);
    }

    .hero-image {
      position: relative;
      height: 400px;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .highlights {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .highlight-card {
      background: rgba(255, 255, 255, 0.05);
      padding: 1.5rem;
      border-radius: 8px;
      border: 1px solid rgba(100, 181, 246, 0.2);
      backdrop-filter: blur(10px);
    }

    .highlight-card h3 {
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
      color: #64b5f6;
    }

    .highlight-card p {
      font-size: 0.95rem;
      color: #b0bec5;
    }

    .about-section {
      padding: 4rem 0;
    }

    .about-section h2 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: #0a0e27;
    }

    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .about-card {
      background: #f5f5f5;
      padding: 2rem;
      border-radius: 8px;
      border-left: 4px solid #64b5f6;
    }

    .about-card h3 {
      font-size: 1.3rem;
      margin-bottom: 1rem;
      color: #0a0e27;
    }

    .about-card p {
      color: #555;
      line-height: 1.7;
    }

    .cta-section {
      background: linear-gradient(135deg, #0a0e27 0%, #1a237e 100%);
      color: #ffffff;
      padding: 3rem 0;
      text-align: center;
      margin-top: 4rem;
    }

    .cta-section h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .cta-section p {
      font-size: 1.1rem;
      margin-bottom: 2rem;
      color: #e0e0e0;
    }

    @media (max-width: 768px) {
      .hero .container {
        grid-template-columns: 1fr;
      }

      .hero-content h1 {
        font-size: 2.5rem;
      }

      .hero-content p {
        font-size: 1.1rem;
      }

      .hero-image {
        height: 300px;
      }

      .hero-buttons {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        text-align: center;
      }

      .about-section h2 {
        font-size: 2rem;
      }
    }
  </style>

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>CloudConf 2026</h1>
        <p>The premier one-day cloud infrastructure conference for engineers. Explore Kubernetes, serverless architectures, and platform engineering best practices.</p>
        <div class="hero-buttons">
          <a href={`${import.meta.env.BASE_URL}register`} class="btn btn-primary">Register Now</a>
          <a href={`${import.meta.env.BASE_URL}schedule`} class="btn btn-secondary">View Schedule</a>
        </div>
        <div class="highlights">
          <div class="highlight-card">
            <h3>📅 May 15, 2026</h3>
            <p>One full day of talks, workshops, and networking</p>
          </div>
          <div class="highlight-card">
            <h3>📍 San Francisco</h3>
            <p>In-person event in the heart of tech</p>
          </div>
          <div class="highlight-card">
            <h3>🎤 Expert Speakers</h3>
            <p>Industry leaders sharing insights and experience</p>
          </div>
        </div>
      </div>
      <div class="hero-image">
        <img src={`${import.meta.env.BASE_URL}assets/event-image-1.png`} alt="CloudConf 2026 Hero Banner" />
      </div>
    </div>
  </section>

  <section class="about-section">
    <div class="container">
      <h2>About CloudConf 2026</h2>
      <div class="about-grid">
        <div class="about-card">
          <h3>🚀 Kubernetes</h3>
          <p>Deep dive into container orchestration, scaling strategies, and production best practices with Kubernetes experts.</p>
        </div>
        <div class="about-card">
          <h3>⚡ Serverless</h3>
          <p>Explore serverless architectures, cost optimization, and building event-driven applications at scale.</p>
        </div>
        <div class="about-card">
          <h3>🏗️ Platform Engineering</h3>
          <p>Learn how to build internal developer platforms that accelerate innovation and improve developer experience.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Join Us?</h2>
      <p>Secure your spot at CloudConf 2026 and connect with cloud engineers from around the world.</p>
      <a href={`${import.meta.env.BASE_URL}register`} class="btn btn-primary">Register Today</a>
    </div>
  </section>
</Layout>
